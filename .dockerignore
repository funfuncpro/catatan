# dependencies (bun install)
apps/auth/**/node_modules

# output
apps/auth/**/out
apps/auth/**/dist
apps/auth/**/*.tgz

# code coverage
apps/auth/**/coverage
apps/auth/**/*.lcov

# logs
apps/auth/**/logs
apps/auth/**/_.log
apps/auth/**/report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

