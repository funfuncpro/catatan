{application,catatan_backend,
    [{modules,
         ['Elixir.CatatanBackend','Elixir.CatatanBackend.Application',
          'Elixir.CatatanBackend.Mailer','Elixir.CatatanBackendWeb',
          'Elixir.CatatanBackendWeb.Endpoint',
          'Elixir.CatatanBackendWeb.ErrorJSON',
          'Elixir.CatatanBackendWeb.Gettext',
          'Elixir.CatatanBackendWeb.HelloController',
          'Elixir.CatatanBackendWeb.Router',
          'Elixir.CatatanBackendWeb.Telemetry']},
     {compile_env,
         [{catatan_backend,
              ['Elixir.CatatanBackendWeb.Endpoint',code_reloader],
              {ok,true}},
          {catatan_backend,
              ['Elixir.CatatanBackendWeb.Endpoint',debug_errors],
              {ok,true}},
          {catatan_backend,
              ['Elixir.CatatanBackendWeb.Endpoint',force_ssl],
              error},
          {catatan_backend,['Elixir.CatatanBackendWeb.Gettext'],error},
          {catatan_backend,[dev_routes],{ok,true}}]},
     {optional_applications,[]},
     {applications,
         [kernel,stdlib,elixir,logger,runtime_tools,phoenix,swoosh,req,
          telemetry_metrics,telemetry_poller,gettext,jason,dns_cluster,
          bandit]},
     {description,"catatan_backend"},
     {registered,[]},
     {vsn,"0.1.0"},
     {mod,{'Elixir.CatatanBackend.Application',[]}}]}.
